#!/bin/bash

# omarchy:summary=Register the theme marketplace with Omarchy

set -euo pipefail

script_path=$(readlink -f "${BASH_SOURCE[0]}")
script_dir=$(cd "$(dirname "$script_path")" && pwd)
repo_dir=$(cd "$script_dir/.." && pwd)
omarchy_path="${OMARCHY_PATH:-$HOME/.local/share/omarchy}"
elephant_menu_dir="$HOME/.config/elephant/menus"
omarchy_extension_dir="$HOME/.config/omarchy/extensions"
omarchy_menu_extension="$omarchy_extension_dir/menu.sh"
changed="false"

link_if_needed() {
  local source="$1"
  local target="$2"

  if [[ $(readlink "$target" 2>/dev/null || true) != "$source" ]]; then
    ln -snf "$source" "$target"
    changed="true"
  fi
}

install_menu_extension() {
  local start_marker="# >>> omarchy-theme-marketplace"
  local end_marker="# <<< omarchy-theme-marketplace"
  local tmp_file

  mkdir -p "$omarchy_extension_dir"
  touch "$omarchy_menu_extension"

  tmp_file=$(mktemp)
  awk -v start="$start_marker" -v end="$end_marker" '
    $0 == start { skip = 1; next }
    $0 == end { skip = 0; next }
    skip != 1 { print }
  ' "$omarchy_menu_extension" >"$tmp_file"

  cat >>"$tmp_file" <<'EOF'
# >>> omarchy-theme-marketplace
show_style_menu() {
  case $(menu "Style" "󰸌  Theme\n󰣇  Theme Marketplace\n󰟵  Unlock\n  Font\n  Background\n  Hyprland\n󱄄  Screensaver\n  About") in
  *"Theme Marketplace"*) show_theme_marketplace_menu ;;
  *Theme*) show_theme_menu ;;
  *Unlock*) omarchy-launch-walker -m menus:omarchyunlocks --width 800 --minheight 400 ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *Hyprland*) open_in_editor ~/.config/hypr/looknfeel.conf ;;
  *Screensaver*) show_screensaver_menu ;;
  *About*) show_about_menu ;;
  *) show_main_menu ;;
  esac
}

show_theme_marketplace_menu() {
  omarchy-theme-marketplace
}
# <<< omarchy-theme-marketplace
EOF

  if ! cmp -s "$tmp_file" "$omarchy_menu_extension"; then
    mv "$tmp_file" "$omarchy_menu_extension"
    changed="true"
  else
    rm -f "$tmp_file"
  fi
}

if [[ -f $repo_dir/default/elephant/omarchy_theme_marketplace.lua ]]; then
  provider_source="$repo_dir/default/elephant/omarchy_theme_marketplace.lua"
elif [[ -f /usr/share/omarchy-theme-marketplace/elephant/omarchy_theme_marketplace.lua ]]; then
  provider_source="/usr/share/omarchy-theme-marketplace/elephant/omarchy_theme_marketplace.lua"
else
  echo "Could not find omarchy_theme_marketplace.lua" >&2
  exit 1
fi

if [[ -x $repo_dir/bin/omarchy-theme-marketplace ]]; then
  bin_source_dir="$repo_dir/bin"
elif [[ -x /usr/bin/omarchy-theme-marketplace ]]; then
  bin_source_dir="/usr/bin"
else
  echo "Could not find marketplace commands" >&2
  exit 1
fi

mkdir -p "$elephant_menu_dir"
link_if_needed "$provider_source" "$elephant_menu_dir/omarchy_theme_marketplace.lua"
install_menu_extension

if [[ -d $omarchy_path/bin ]]; then
  link_if_needed "$bin_source_dir/omarchy-theme-marketplace" "$omarchy_path/bin/omarchy-theme-marketplace"
  link_if_needed "$bin_source_dir/omarchy-theme-marketplace-refresh" "$omarchy_path/bin/omarchy-theme-marketplace-refresh"
  link_if_needed "$bin_source_dir/omarchy-theme-marketplace-install" "$omarchy_path/bin/omarchy-theme-marketplace-install"
  link_if_needed "$bin_source_dir/omarchy-theme-marketplace-setup" "$omarchy_path/bin/omarchy-theme-marketplace-setup"
fi

if [[ $changed == "true" ]] && command -v omarchy-restart-walker >/dev/null 2>&1; then
  omarchy-restart-walker || true
fi
